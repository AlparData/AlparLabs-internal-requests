<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Secuencia para PIM -->
        <record id="seq_material_request_pim" model="ir.sequence">
            <field name="name">Pedido Interno de Material</field>
            <field name="code">material.request.pim</field>
            <field name="prefix">PIM-</field>
            <field name="padding">3</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <!-- Secuencia para SIM -->
        <record id="seq_material_request_sim" model="ir.sequence">
            <field name="name">Solicitud Interna de Material</field>
            <field name="code">material.request.sim</field>
            <field name="prefix">SIM-</field>
            <field name="padding">3</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

    </data>
</odoo>
