<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pim_create_po_wizard_form" model="ir.ui.view">
        <field name="name">pim.create.po.wizard.form</field>
        <field name="model">pim.create.po.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Presupuesto">
                <group>
                    <field name="pim_id" invisible="1"/>
                    <field name="partner_id" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_create_po" string="Crear RFQ" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
