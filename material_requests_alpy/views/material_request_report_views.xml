<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_material_request_report_list" model="ir.ui.view">
        <field name="name">material.request.report.list</field>
        <field name="model">material.request.report</field>
        <field name="arch" type="xml">
            <list string="Tablero General" create="false" edit="false" delete="false"
                  decoration-info="request_type == 'pim'"
                  decoration-warning="request_type == 'sim'">
                <field name="date_request"/>
                <field name="name"/>
                <field name="request_type" widget="badge" 
                       decoration-info="request_type == 'pim'" 
                       decoration-warning="request_type == 'sim'"/>
                <field name="project_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_material_request_report_kanban" model="ir.ui.view">
        <field name="name">material.request.report.kanban</field>
        <field name="model">material.request.report</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" create="false" edit="false" delete="false" default_group_by="request_type">
                <field name="name"/>
                <field name="request_type"/>
                <field name="project_id"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="date_request"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span class="badge rounded-pill" t-attf-class="{{ record.request_type.raw_value == 'pim' ? 'text-bg-info' : 'text-bg-warning' }}">
                                    <field name="request_type"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-building-o" title="Obra"/> <field name="project_id"/></div>
                                <div><i class="fa fa-clock-o" title="Fecha"/> <field name="date_request"/></div>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <span class="badge text-bg-secondary"><field name="state"/></span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_material_request_report_search" model="ir.ui.view">
        <field name="name">material.request.report.search</field>
        <field name="model">material.request.report</field>
        <field name="arch" type="xml">
            <search string="Buscar Solicitudes">
                <field name="name"/>
                <field name="project_id"/>
                <field name="user_id"/>
                <filter string="Mis Solicitudes" name="my_reqs" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Solo Pañol (PIM)" name="filter_pim" domain="[('request_type', '=', 'pim')]"/>
                <filter string="Solo Compras (SIM)" name="filter_sim" domain="[('request_type', '=', 'sim')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Tipo" name="group_type" context="{'group_by': 'request_type'}"/>
                    <filter string="Obra" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Solicitante" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_material_request_report" model="ir.actions.act_window">
        <field name="name">Vista General (PIM y SIM)</field>
        <field name="res_model">material.request.report</field>
        <field name="view_mode">list,kanban</field>
        <field name="search_view_id" ref="view_material_request_report_search"/>
        <field name="context">{'search_default_group_type': 1}</field>
    </record>

    <menuitem id="menu_report_all"
              name="Todas las Solicitudes"
              parent="menu_material_requests_root"
              action="action_material_request_report"
              sequence="5"/>
</odoo>
