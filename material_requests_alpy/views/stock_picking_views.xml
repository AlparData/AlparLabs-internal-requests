<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_material_requests" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.material.requests</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="%(material_requests_alpy.action_pim_list)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-cubes"
                        invisible="not pim_id"
                        context="{'search_default_id': pim_id}">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Ver PIM</span>
                    </div>
                </button>
            </div>
            <!-- Optionally show the pim_id field -->
            <field name="origin" position="after">
                <field name="pim_id" readonly="1" invisible="not pim_id"/>
            </field>
        </field>
    </record>
</odoo>
