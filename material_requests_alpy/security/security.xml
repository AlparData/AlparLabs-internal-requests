<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!-- MODULE CATEGORY                                              -->
        <!-- ============================================================ -->
        <record id="module_category_material_requests" model="ir.module.category">
            <field name="name">Abastecimiento</field>
            <field name="description">Gestión de Solicitudes y Pedidos Internos de Material</field>
            <field name="sequence">50</field>
        </record>

        <!-- ============================================================ -->
        <!-- SECURITY GROUPS                                              -->
        <!-- ============================================================ -->

        <!-- Usuario de Obra: Puede crear PIM -->
        <record id="group_obra_user" model="res.groups">
            <field name="name">Usuario de Obra</field>
            <field name="category_id" ref="module_category_material_requests"/>
            <field name="comment">Puede crear PIM. Solo ve sus propios registros.</field>
        </record>

        <!-- Jefe de Obra / Gerencia: Aprueba o Rechaza PIMs -->
        <record id="group_obra_manager" model="res.groups">
            <field name="name">Admin. Total (Gerencia)</field>
            <field name="category_id" ref="module_category_material_requests"/>
            <field name="implied_ids" eval="[(4, ref('group_obra_user'))]"/>
            <field name="comment">Administrador total. Ve todos los registros y puede anular todo.</field>
        </record>

        <!-- Compras: Gestiona estados de PIM (Cotización/OC) -->
        <record id="group_purchasing" model="res.groups">
            <field name="name">Compras</field>
            <field name="category_id" ref="module_category_material_requests"/>
            <field name="implied_ids" eval="[(4, ref('group_obra_user'))]"/>
            <field name="comment">Gestiona los estados del PIM (Cotización/Orden de Compra).</field>
        </record>

        <!-- ============================================================ -->
        <!-- RECORD RULES                                                 -->
        <!-- ============================================================ -->

        <!-- Usuario de Obra: Solo sus propios registros PIM -->
        <record id="rule_pim_obra_user" model="ir.rule">
            <field name="name">PIM: Solo mis registros</field>
            <field name="model_id" ref="model_material_request_pim"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_obra_user'))]"/>
        </record>

        <!-- Jefe de Obra: Ve todos los registros PIM -->
        <record id="rule_pim_obra_manager" model="ir.rule">
            <field name="name">PIM: Todos los registros (Administrador Total)</field>
            <field name="model_id" ref="model_material_request_pim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_obra_manager'))]"/>
        </record>

        <!-- Compras: Ve todos los PIM -->
        <record id="rule_pim_purchasing" model="ir.rule">
            <field name="name">PIM: Todos los registros (Compras)</field>
            <field name="model_id" ref="model_material_request_pim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_purchasing'))]"/>
        </record>

    </data>
</odoo>
