<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!-- MODULE CATEGORY                                              -->
        <!-- ============================================================ -->
        <record id="module_category_material_requests" model="ir.module.category">
            <field name="name">Abastecimiento</field>
            <field name="description">Gestión de Solicitudes y Pedidos Internos de Material</field>
            <field name="sequence">50</field>
        </record>

        <!-- ============================================================ -->
        <!-- SECURITY GROUPS                                              -->
        <!-- ============================================================ -->

        <!-- Usuario de Obra: Puede crear SIM y PIM, solo ve sus propios pedidos -->
        <record id="group_obra_user" model="res.groups">
            <field name="name">Usuario de Obra</field>
            <field name="category_id" ref="module_category_material_requests"/>
            <field name="comment">Puede crear SIM y PIM. Solo ve sus propios pedidos.</field>
        </record>

        <!-- Jefe de Obra / Gerencia: Aprueba o Rechaza SIMs y PIMs -->
        <record id="group_obra_manager" model="res.groups">
            <field name="name">Jefe de Obra / Gerencia</field>
            <field name="category_id" ref="module_category_material_requests"/>
            <field name="implied_ids" eval="[(4, ref('group_obra_user'))]"/>
            <field name="comment">Aprueba o rechaza SIMs y PIMs. Ve todos los registros.</field>
        </record>

        <!-- Logística (Pañol): Gestiona estados de SIM (Despacho/Entrega) -->
        <record id="group_logistics" model="res.groups">
            <field name="name">Logística (Pañol)</field>
            <field name="category_id" ref="module_category_material_requests"/>
            <field name="implied_ids" eval="[(4, ref('group_obra_user'))]"/>
            <field name="comment">Gestiona los estados de la SIM (Despachado/Entregado).</field>
        </record>

        <!-- Compras: Gestiona estados de PIM (Cotización/OC) -->
        <record id="group_purchasing" model="res.groups">
            <field name="name">Compras</field>
            <field name="category_id" ref="module_category_material_requests"/>
            <field name="implied_ids" eval="[(4, ref('group_obra_user'))]"/>
            <field name="comment">Gestiona los estados de la PIM (Cotización/Orden de Compra).</field>
        </record>

        <!-- ============================================================ -->
        <!-- RECORD RULES                                                 -->
        <!-- ============================================================ -->

        <!-- Usuario de Obra: Solo sus propios registros SIM -->
        <record id="rule_sim_obra_user" model="ir.rule">
            <field name="name">SIM: Solo mis registros</field>
            <field name="model_id" ref="model_material_request_sim"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_obra_user'))]"/>
        </record>

        <!-- Usuario de Obra: Solo sus propios registros PIM -->
        <record id="rule_pim_obra_user" model="ir.rule">
            <field name="name">PIM: Solo mis registros</field>
            <field name="model_id" ref="model_material_request_pim"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_obra_user'))]"/>
        </record>

        <!-- Jefe de Obra: Ve todos los registros SIM -->
        <record id="rule_sim_obra_manager" model="ir.rule">
            <field name="name">SIM: Todos los registros (Gerencia)</field>
            <field name="model_id" ref="model_material_request_sim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_obra_manager'))]"/>
        </record>

        <!-- Jefe de Obra: Ve todos los registros PIM -->
        <record id="rule_pim_obra_manager" model="ir.rule">
            <field name="name">PIM: Todos los registros (Gerencia)</field>
            <field name="model_id" ref="model_material_request_pim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_obra_manager'))]"/>
        </record>

        <!-- Logística: Ve todos los SIM -->
        <record id="rule_sim_logistics" model="ir.rule">
            <field name="name">SIM: Todos los registros (Logística)</field>
            <field name="model_id" ref="model_material_request_sim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_logistics'))]"/>
        </record>

        <!-- Compras: Ve todos los PIM -->
        <record id="rule_pim_purchasing" model="ir.rule">
            <field name="name">PIM: Todos los registros (Compras)</field>
            <field name="model_id" ref="model_material_request_pim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_purchasing'))]"/>
        </record>

    </data>
</odoo>
